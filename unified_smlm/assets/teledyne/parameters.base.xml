<?xml version='1.0' encoding='UTF-8'?>
<para>
    <focusLock>
        <camModel>DCC</camModel>
        <!--CS is new thorlabs camera, DCC is old one-->
        <piezoComm>RS232</piezoComm>
        <!--RS232 or USB-->
        <piezoPara>COM4</piezoPara>
        <!--eg. RS232(COM8); USB(PI E-709) -->
        <aoi_x>400</aoi_x>
        <aoi_y>446</aoi_y>
        <aoi_w>300</aoi_w>
        <aoi_h>300</aoi_h>
        <targetFPS>50</targetFPS>
        <!--only for DCC camera -->
        <imgExposure>10000</imgExposure>
        <!--only for CS camera, us -->
        <refPos>0.20</refPos>
        <!-- reset position UNIT: mm-->
        <Kp>0.1</Kp>
        <Ki>0.08</Ki>
        <Kd>0.001</Kd>
        <pixConveRatio>0.001</pixConveRatio>
        <!-- pixel to milimeter ratio -->
        <spotSize>41</spotSize>
        <spotAmp>10.0</spotAmp>
        <spotX>21.0</spotX>
        <spotY>21.0</spotY>
        <spotWidth>3.0</spotWidth>
        <spotOffset>10.0</spotOffset>
    </focusLock>
